---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/base.astro";
const entry = await getEntry("views", "error404");
if (!entry) {
  throw new Error("404 page not found");
}
const [HERO] = entry.data.blocks;
---
<BaseLayout entry={entry}>
  <div class="container flex flex-col items-center justify-center py-20 text-center gap-4">
    <p class="text-8xl">🌿</p>
    <h1 class="text-4xl font-bold">{HERO.title}</h1>
    <p class="text-base-content/70 max-w-md">{HERO.description}</p>
    <a href={HERO.link_url} class="btn mt-2" style="background-color: #ff6b35; border-color: #ff6b35; color: white;">
      {HERO.link_text}
    </a>
  </div>
</BaseLayout>
