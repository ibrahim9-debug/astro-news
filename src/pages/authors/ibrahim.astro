---
import BaseLayout from "@/layouts/base.astro";
import ContentLayout from "@/layouts/content.astro";
import { getEntry } from "astro:content";
const author = await getEntry("authors", "ibrahim");
if (!author) {
  return Astro.redirect("/404");
}
const entry = await getEntry("views", "about");
if (!entry) {
  return Astro.redirect("/404");
}
---
<BaseLayout entry={entry}>
  <ContentLayout>
    <div class="flex flex-col items-center text-center gap-6 py-12">
      <img
        src={author.data.avatar.src}
        alt={author.data.name}
        class="w-24 h-24 rounded-full object-cover"
      />
      <div>
        <h1 class="text-3xl font-bold">{author.data.name}</h1>
        <p class="text-base-content/70 mt-1">{author.data.job}</p>
      </div>
      <p class="max-w-xl text-base-content/80">{author.data.bio}</p>
    </div>
    <div class="flex justify-center pb-12">
      <a href="https://x.com/calmajadotcom" target="_blank" rel="noopener noreferrer" class="btn" style="background-color: #ff6b35; border-color: #ff6b35; color: white;">
        Follow di X
      </a>
    </div>
  </ContentLayout>
</BaseLayout>
