---
import ListLayout from "@/layouts/list.astro";
import { getEntry } from "astro:content";
const entry = await getEntry("views", "categories");
if (!entry) {
  return Astro.redirect("/404");
}
---
<ListLayout header={"Sitemap"} entry={entry}>
  <div class="w-full space-y-8 my-6">
    <div class="flex items-center w-full justify-between gap-2 border-b border-accent/30 pb-2">
      <h2 class="text-xl">
        Cerita Pribadi
      </h2>
      <a href="/categories/cerita-pribadi/1" style="color: #ff6b35; font-size: 0.875rem;">
        Lihat Semua →
      </a>
    </div>
    <div class="flex items-center w-full justify-between gap-2 border-b border-accent/30 pb-2">
      <h2 class="text-xl">
        Mindful
      </h2>
      <a href="/categories/mindful/1" style="color: #ff6b35; font-size: 0.875rem;">
        Lihat Semua →
      </a>
    </div>
  </div>
</ListLayout>
