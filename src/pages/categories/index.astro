---
import ListLayout from "@/layouts/list.astro";
import { getEntry } from "astro:content";
import { categoriesHandler } from "@/lib/handlers/categories";
const entry = await getEntry("views", "categories");
if (!entry) {
  return Astro.redirect("/404");
}
const categories = categoriesHandler.allCategoriesWithLatestArticles();
---
<ListLayout header={"Sitemap"} entry={entry}>
  <div class="w-full space-y-8 my-6">
    {categories.map((category) => (
      <div class="flex items-center w-full justify-between gap-2 border-b border-accent/30 pb-2">
        <h2 class="text-xl inline-flex items-center gap-2">
          {category.data.title}
          <span class="text-xs font-sans" style="color: #ff6b35;">
            ({category.data.count} Artikel)
          </span>
        </h2>
        
          href={`/categories/${category.data.path}/1`}
          style="color: #ff6b35; font-size: 0.875rem;"
        >
          Lihat Semua →
        </a>
      </div>
    ))}
  </div>
</ListLayout>
